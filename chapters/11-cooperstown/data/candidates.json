  "_metadata": {
    "title": "Cooperstown Candidates: Negro Leagues Players with Documented Hall of Fame Cases",
    "description": "Negro Leagues players whose documented statistics and historian advocacy suggest Hall of Fame candidacy, evaluated against the JAWS position-by-position bar. Career WAR figures are from the Chapter 10 Ledger (Seamheads database). Peak WAR and JAWS are computed where sufficient data exists. Players are categorized as 'inducted' (already in Cooperstown), 'candidate_strong' (historian advocacy plus statistical case), or 'candidate_documented' (statistical record exists, case has been argued).",
    "sources": [
      {
        "id": "ch10-ledger",
        "name": "Chapter 10: The Ledger (players.json)",
        "url": "https://theotherboxscore.org/chapters/the-ledger/",
        "note": "Career WAR, batting/pitching stats, rateWAR from Seamheads Negro Leagues Database"
      },
      {
        "id": "ch12-matrix",
        "name": "Chapter 12: The Other Hall (hall-matrix.json)",
        "url": "https://theotherboxscore.org/chapters/the-other-hall/",
        "note": "Cooperstown induction years and multi-hall status"
      },
      {
        "id": "42for21",
        "name": "42 for 21 Committee",
        "url": "https://www.42for21.org/results",
        "accessed": "2026-05-24",
        "note": "Poll of 70+ historians ranking Negro Leagues HOF candidates"
      },
      {
        "id": "hof-standards",
        "name": "hof-standards.json",
        "note": "JAWS position averages from FanGraphs"
      },
      {
        "id": "seamheads",
        "name": "Seamheads Negro Leagues Database",
        "url": "https://www.seamheads.com/NegroLgs/"
      }
    ],
    "methodology_notes": [
      "Career WAR is directly from Ch 10 Ledger (Seamheads source).",
      "Peak WAR (best 7 seasons) is NOT available from the Seamheads all-time leaderboard view. Marked null for all players. Per-season WAR breakdowns would be required to compute this figure.",
      "JAWS = (career WAR + peak 7-yr WAR) / 2. Because peak WAR is null, JAWS cannot be computed from the available data. The 'estimatedJAWS' field uses the approximation: career WAR * 0.75, which is the typical ratio of JAWS to career WAR for position players in the MLB JAWS database. This is labeled 'Modeled' confidence.",
      "rateWAR is from Ch 10: (career WAR / PA) * 600 for batters, (career WAR / IP) * 200 for pitchers.",
      "The 'barComparison' field compares the player's estimated JAWS to the position average from hof-standards.json.",
      "Historian advocacy is documented from the 42 for 21 Committee results and other published sources.",
      "Players not in the Ch 10 top 50 have careerWAR marked null with an explanatory note."
    ],
    "confidence_vocabulary": {
      "Documented": "Figure appears in Seamheads database with game-level source data",
      "Estimated": "Figure derived from documented data via rate computation",
      "Modeled": "Figure produced by approximation model (e.g., JAWS estimation from career WAR)"
    },
    "generated": "2026-05-24"
  },
