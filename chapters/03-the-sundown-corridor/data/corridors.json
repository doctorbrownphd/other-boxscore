      "upper_bound": "Danger score multiplied by 2.5x to estimate undocumented sundown towns, capped at 1.0",
      "lower_bound": "Confirmed-only towns, same normalization",
      "route_geometry": "Great-circle distance between city pairs. Period-accurate road routing would increase distances and potentially capture additional sundown towns near road curves."
    },
    "source": {
      "sundown_towns": "Scientific Data (2025) geocoded dataset, DOI: 10.1038/s41597-024-04330-9",
      "game_locations": "Seamheads Negro Leagues Database, SABR Ballparks Database",
      "methodology_note": "Route distances use great-circle approximation. Actual 1936-1948 road distances were longer. Danger scores are lower-bound estimates."
    },
